<VBox alignment="CENTER" prefHeight="420.0" prefWidth="492.0" spacing="5.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.GUI.SelectController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Interpreter">
            <font>
                <Font name="Bodoni MT Black Italic" size="36.0" />
            </font>
        </Text>
        <ListView fx:id="programs" prefHeight="250.0" prefWidth="200.0" />
        <Text fx:id="typerchecker" fill="RED" strokeType="OUTSIDE" strokeWidth="0.0" textAlignment="CENTER" wrappingWidth="230.0">
            <font>
                <Font name="System Bold" size="11.0" />
            </font>
        </Text>
        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Select Program">
            <font>
                <Font name="Bodoni MT Black Italic" size="26.0" />
            </font>
        </Text>
        <Button contentDisplay="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#execute" style="-fx-background-color: #ff9b11;" text="Execute" textAlignment="CENTER">
            <font>
                <Font name="Bodoni MT Black Italic" size="18.0" />
            </font></Button>
    </children>

</VBox>
